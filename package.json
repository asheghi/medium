{
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "npm run server",
    "prod": "npm run build && npm run server:prod",
    "build": "dotenv vike build && npm run prisma:gen",
    "server": "npx dotenv node ./server",
    "server:prod": "cross-env NODE_ENV=production node ./server",
    "start": "npm run server:prod",
    "postinstall": "npm run prisma:gen",
    "lint": "eslint . --ext .js,.vue",
    "lint-fix": "eslint . --ext .js,.vue --fix",
    "test": "npm run test:unit",
    "test:unit": "node --test test/unit/*.test.js",
    "admin:create": "dotenv node ./scripts/admin-create.js",
    "prisma:gen": "prisma generate",
    "prisma:dev": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio -p 8080",
    "start:docker": "npm run prisma:deploy && npm run server:prod",
    "test:e2e": "npm run prisma:deploy & npm run dev & wait-on http://localhost:3000 & cypress run"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/typography": "^0.5.1",
    "@tiptap/extension-bubble-menu": "^2.0.0-beta.55",
    "@tiptap/extension-code-block-lowlight": "^2.0.0-beta.68",
    "@tiptap/extension-document": "^2.0.0-beta.15",
    "@tiptap/extension-heading": "^2.0.0-beta.26",
    "@tiptap/extension-image": "^2.0.0-beta.25",
    "@tiptap/extension-link": "^2.0.0-beta.36",
    "@tiptap/extension-paragraph": "^2.0.0-beta.23",
    "@tiptap/extension-text": "^2.0.0-beta.15",
    "@tiptap/extension-text-align": "^2.0.0-beta.29",
    "@tiptap/starter-kit": "^2.0.0-beta.181",
    "@tiptap/vue-3": "^2.0.0-beta.90",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.35",
    "@vue/server-renderer": "^3.5.35",
    "axios": "^1.17.0",
    "body-parser": "^1.19.1",
    "cookie-parser": "^1.4.6",
    "cross-env": "^7.0.3",
    "debug": "^4.3.3",
    "express": "^4.17.1",
    "express-rate-limit": "^8.5.2",
    "hash": "^0.2.1",
    "helmet": "^8.2.0",
    "highlight.js": "^11.4.0",
    "lodash.debounce": "^4.0.8",
    "lowlight": "^3.3.0",
    "marked": "^4.0.12",
    "minio": "^8.0.7",
    "moment": "^2.29.1",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "qs": "^6.10.3",
    "sanitize-html": "^2.17.4",
    "sass": "^1.100.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.5",
    "vike": "^0.4.259",
    "vike-vue": "^0.9.11",
    "vite": "^8.0.16",
    "vite-svg-loader": "^5.1.1",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.2",
    "cypress": "^9.5.0",
    "dotenv-cli": "^4.1.1",
    "eslint": "^8.8.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-vue": "^8.4.0",
    "postcss": "^8.4.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.0.18",
    "wait-on": "^6.0.1"
